import cv2
from pyzbar.pyzbar import decode
import time


cap = cv2.VideoCapture(0)


cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)

print("Scanning for QR codes... Press 'q' to quit.")

while True:
    success, frame = cap.read()
    if not success:
        print("Camera not found or failed to grab frame.")
        break

    for code in decode(frame):
		data = code.data.decode('utf-8')
      
        if data == 'Friend!':
            print("Friend Detected")
        elif data == 'Enemy!':
            print("Enemy Detected")
        elif data == 'BiggerEnemy!':
            print("BiggerEnemy Detected")
        elif data == 'Lover!':
            print("Lover Detected")
        else:
            print(f"Unknown code detected: {data}")

    try:
		cv2.imshow('PiScan', frame)
	except cv2.error:
		pass
		
	if cv2.waitKey(1) & 0xFF == ord('q'):
		break

cap.release()
cv2.destroyAllWindows()
